{
  "name": "desk365-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run check:staging-urls",
    "preview": "astro preview",
    "check:staging-urls": "node -e \"const {execSync}=require('child_process');try{execSync('grep -r staging.desk365.io dist/',{stdio:'pipe'});process.exit(1)}catch{process.exit(0)}\""
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.3",
    "@astrojs/vercel": "^7.8.1",
    "@sanity/client": "^6.22.5",
    "@sanity/image-url": "^1.1.0",
    "@sanity/preview-url-secret": "^2.1.16",
    "@sanity/visual-editing": "^2.15.4",
    "astro": "^4.16.18",
    "tailwindcss": "^3.4.17"
  }
}
