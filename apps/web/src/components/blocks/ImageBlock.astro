---
import type { PageSectionBlock } from '../../lib/types';
import {
  resolveSpacing, resolveBorder, resolveSize, mergeStyles,
  resolveResponsiveCss, resolveScopedCss,
} from '../../lib/styleResolver';

interface Props {
  block: PageSectionBlock;
  isPreview?: boolean;
  dataSanity?: string;
}

const { block, isPreview, dataSanity } = Astro.props;
const {
  image,
  caption,
  link,
  openInNewTab,
  alignment = 'left',
  blockId,
  blockClass,
} = block;

const objectFit   = (block as any).objectFit   ?? 'cover';
const aspectRatio = (block as any).aspectRatio ?? 'auto';

const id  = blockId  || `block-${block._key}`;
const cls = blockClass || `image-${block._key}`;

const alignItems =
  alignment === 'center' ? 'items-center' : alignment === 'right' ? 'items-end' : 'items-start';

const figureStyle = mergeStyles(
  resolveSpacing(block.spacing),
  resolveSize(block.size),
);

const imgStyle = mergeStyles(
  `object-fit:${objectFit}`,
  aspectRatio !== 'auto' ? `aspect-ratio:${aspectRatio}` : '',
  resolveBorder(block.border),
  'width:100%',
);

const responsiveCss = resolveResponsiveCss(cls, block.responsive);
const scopedCss     = resolveScopedCss(cls, block.customCss);
---

{(responsiveCss || scopedCss) && (
  <style is:inline set:html={responsiveCss + scopedCss} />
)}

<figure
  id={id}
  class:list={[cls, 'flex flex-col', alignItems, isPreview && 'pb-outline-block']}
  style={figureStyle || undefined}
  data-block-type="imageBlock"
  data-sanity={dataSanity}
>
  {image?.asset?.url ? (
    link ? (
      <a
        href={link}
        target={openInNewTab ? '_blank' : '_self'}
        rel={openInNewTab ? 'noopener noreferrer' : undefined}
      >
        <img src={image.asset.url} alt={image?.alt ?? ''} style={imgStyle} loading="lazy" />
      </a>
    ) : (
      <img src={image.asset.url} alt={image?.alt ?? ''} style={imgStyle} loading="lazy" />
    )
  ) : isPreview ? (
    <div style="display:flex;align-items:center;justify-content:center;border-radius:12px;background:#f1f5f9;border:2px dashed #cbd5e1;min-height:200px;width:100%;">
      <span style="color:#94a3b8;font-size:13px;font-family:sans-serif;">📷 No image — click to add</span>
    </div>
  ) : null}
  {caption && <figcaption class="text-sm text-gray-500 mt-2">{caption}</figcaption>}
</figure>
