---
import type { PageSectionBlock } from '../../lib/types';

interface Props {
  block: PageSectionBlock;
  isPreview?: boolean;
  dataSanity?: string;
}

const { block, isPreview, dataSanity } = Astro.props;
const { source = 'custom', items = [], columns = '3', gap = 'md', blockId, blockClass } = block;

const id = blockId || `block-${block._key}`;
const cls = blockClass || `loopgrid-${block._key}`;

const colMap: Record<string, string> = {
  '1': 'grid-cols-1',
  '2': 'grid-cols-1 sm:grid-cols-2',
  '3': 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  '4': 'grid-cols-2 lg:grid-cols-4',
};
const gapMap: Record<string, string> = {
  none: 'gap-0',
  xs: 'gap-2',
  sm: 'gap-4',
  md: 'gap-6',
  lg: 'gap-8',
  xl: 'gap-12',
};

const hideClasses = [
  block.hideOnMobile && 'hidden md:grid',
  block.hideOnDesktop && 'grid md:hidden',
].filter(Boolean);
---

<div
  id={id}
  class:list={[
    cls,
    'grid',
    colMap[columns] ?? colMap['3'],
    gapMap[gap] ?? gapMap.md,
    ...hideClasses,
    isPreview && 'pb-outline-block',
  ]}
  data-block-type="loopGridBlock"
  data-sanity={dataSanity}
>
  {items.map(item => (
    <div class="flex flex-col gap-3">
      {item.image?.asset?.url && (
        <img
          src={item.image.asset.url}
          alt={item.description ?? ''}
          class="w-full rounded-lg object-cover"
          loading="lazy"
        />
      )}
      {item.title && <h3 class="font-semibold text-gray-900">{item.title}</h3>}
      {item.description && <p class="text-gray-600 text-sm">{item.description}</p>}
      {item.link && (
        <a href={item.link} class="text-blue-600 hover:underline text-sm">
          Learn more &rarr;
        </a>
      )}
    </div>
  ))}
  {items.length === 0 && isPreview && (
    <div class="col-span-full text-gray-400 text-sm text-center py-8 border-2 border-dashed border-gray-200 rounded-lg">
      Loop Grid &mdash; source: {source}. Add items or connect a data source.
    </div>
  )}
</div>
