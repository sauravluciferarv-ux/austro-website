---
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';
import type { D365TrustBarSection } from '../../lib/types';

interface Props {
  data?: D365TrustBarSection;
  isPreview?: boolean;
  docId?: string;
  docType?: string;
}

const { data, docId, docType = 'homepage' } = Astro.props;

const heading = data?.heading ?? 'Trusted by 7,000+ businesses around the world';

const baseUrl = 'https://www.desk365.io/wp-content/uploads';

const staticRow1 = [
  { name: 'CBRE',          src: `${baseUrl}/2025/12/CBRE.png.webp` },
  { name: 'LAPD',          src: `${baseUrl}/2025/12/LAPD.png.webp` },
  { name: 'Panasonic',     src: `${baseUrl}/2025/12/Panasonic.png.webp` },
  { name: 'MMRO',          src: `${baseUrl}/2025/12/MMRO.png.webp`,   href: '/customers/mmro/', badge: 'Switched from Zendesk' },
  { name: 'BBC',           src: `${baseUrl}/2025/12/BBC.png.webp` },
  { name: 'CCKeys',        src: `${baseUrl}/2025/12/CCKeys.png.webp`,  href: '/customers/cckeys/', badge: 'Case study' },
  { name: 'Pioneer',       src: `${baseUrl}/2025/12/Pioneer.png.webp` },
  { name: 'SMC',           src: `${baseUrl}/2025/12/SMC.png.webp` },
  { name: 'Concurrent',    src: `${baseUrl}/2025/12/Concurrent.png.webp`, href: '/customers/concurrent/', badge: 'Case study' },
  { name: 'Capra Bank',    src: `${baseUrl}/2025/12/Capra-Bank.png.webp` },
  { name: 'Yamaha',        src: `${baseUrl}/2025/12/Yamaha.png.webp` },
];

const staticRow2 = [
  { name: 'Konica Minolta',              src: `${baseUrl}/2025/12/Konica-Minolta.png.webp` },
  { name: 'Tuttnauer',                   src: `${baseUrl}/2025/12/Tuttnauer.png.webp`, href: '/customers/tuttnauer/', badge: 'Chosen over Zendesk' },
  { name: 'Standard Bank',               src: `${baseUrl}/2025/12/Standard-Bank.png.webp` },
  { name: 'The Philadelphia Contributionship', src: `${baseUrl}/2025/12/Philadelphia.png.webp` },
  { name: 'University of Kentucky',      src: `${baseUrl}/2025/12/University-of-Kentucky.png.webp` },
  { name: 'Class Technology',            src: `${baseUrl}/2025/12/Class-Technology.png.webp`, href: '/customers/cts-uk/', badge: 'Case study' },
  { name: 'El Cronista',                 src: `${baseUrl}/2025/12/El-Cronista.png.webp` },
  { name: "Nation's Best",               src: `${baseUrl}/2025/12/Nations-Best.png.webp` },
  { name: 'HPSC',                        src: `${baseUrl}/2025/12/HPSC.png.webp`, href: '/customers/hpsc/', badge: 'Case study' },
  { name: 'Edgewater',                   src: `${baseUrl}/2025/12/Edgewater.png.webp` },
  { name: 'Leedstone',                   src: `${baseUrl}/2025/12/Leedstone.png.webp` },
];

const logosRow1 = data?.logosRow1?.length
  ? data.logosRow1.map(l => ({ name: l.name, src: l.logo?.asset?.url ?? '', href: l.href, badge: l.badge }))
  : staticRow1;

const logosRow2 = data?.logosRow2?.length
  ? data.logosRow2.map(l => ({ name: l.name, src: l.logo?.asset?.url ?? '', href: l.href, badge: l.badge }))
  : staticRow2;

let sanityAttr: string | undefined;
if (docId && data?._key) {
  try {
    const da = createDataAttribute({ id: docId, type: docType });
    sanityAttr = da(`pageBuilder[_key=="${data._key}"]`);
  } catch {}
}
---

<section id="d365-trust" class="d365-trust d365-section--white" data-sanity={sanityAttr}>
  <div class="d365-container">
    <p class="d365-trust__heading">{heading}</p>
  </div>

  <!-- Row 1 marquee -->
  <div class="d365-trust__marquee-wrap" aria-hidden="true">
    <div class="d365-trust__track">
      {[...logosRow1, ...logosRow1].map(logo => (
        <div class="d365-trust__logo-item">
          {logo.href ? (
            <a href={logo.href} class="d365-trust__logo-link" title={logo.name}>
              <img src={logo.src} alt={logo.name} class="d365-trust__logo-img" loading="lazy" />
              {logo.badge && <span class="d365-trust__badge">{logo.badge}</span>}
            </a>
          ) : (
            <img src={logo.src} alt={logo.name} class="d365-trust__logo-img" loading="lazy" />
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- Row 2 marquee (reverse direction) -->
  <div class="d365-trust__marquee-wrap" aria-hidden="true">
    <div class="d365-trust__track d365-trust__track--reverse">
      {[...logosRow2, ...logosRow2].map(logo => (
        <div class="d365-trust__logo-item">
          {logo.href ? (
            <a href={logo.href} class="d365-trust__logo-link" title={logo.name}>
              <img src={logo.src} alt={logo.name} class="d365-trust__logo-img" loading="lazy" />
              {logo.badge && <span class="d365-trust__badge">{logo.badge}</span>}
            </a>
          ) : (
            <img src={logo.src} alt={logo.name} class="d365-trust__logo-img" loading="lazy" />
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .d365-trust {
    padding: 48px 0;
    overflow: hidden;
  }

  .d365-trust__heading {
    font-size: 15px;
    font-weight: 600;
    color: #7c7e9a;
    text-align: center;
    letter-spacing: 0.02em;
    margin: 0 0 32px;
  }

  /* Marquee wrapper: fades edges */
  .d365-trust__marquee-wrap {
    position: relative;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .d365-trust__marquee-wrap::before,
  .d365-trust__marquee-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .d365-trust__marquee-wrap::before {
    left: 0;
    background: linear-gradient(to right, #fff 0%, transparent 100%);
  }
  .d365-trust__marquee-wrap::after {
    right: 0;
    background: linear-gradient(to left, #fff 0%, transparent 100%);
  }

  /* Scrolling track */
  .d365-trust__track {
    display: flex;
    width: max-content;
    animation: d365-marquee-left 35s linear infinite;
    gap: 40px;
    align-items: center;
  }
  .d365-trust__track--reverse {
    animation: d365-marquee-right 38s linear infinite;
  }

  @keyframes d365-marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes d365-marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Pause on hover */
  .d365-trust__marquee-wrap:hover .d365-trust__track {
    animation-play-state: paused;
  }

  /* Individual logo item */
  .d365-trust__logo-item {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    height: 56px;
  }

  .d365-trust__logo-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
  }

  .d365-trust__logo-img {
    height: 36px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
    filter: grayscale(1) opacity(0.6);
    transition: filter 0.2s ease;
  }
  .d365-trust__logo-item:hover .d365-trust__logo-img {
    filter: grayscale(0) opacity(1);
  }

  .d365-trust__badge {
    font-size: 10px;
    font-weight: 700;
    color: var(--d365-blue);
    background: var(--d365-icon-bg);
    border-radius: 20px;
    padding: 2px 8px;
    white-space: nowrap;
  }
</style>
