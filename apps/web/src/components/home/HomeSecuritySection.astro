---
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';
import type { D365SecuritySection, D365SectionStyleProps } from '../../lib/types';

interface Props {
  data?: D365SecuritySection;
  isPreview?: boolean;
  docId?: string;
  docType?: string;
  styleProps?: D365SectionStyleProps;
}

const { data, docId, docType = 'homepage', styleProps } = Astro.props;

const heading = data?.heading ?? 'Security, Safety and Compliance';
const bullets = data?.bullets?.length
  ? data.bullets
  : [
      'At Desk365, ensuring the security of your data is our top priority. We adhere to stringent security policies and controls that meet leading industry standards.',
      'To cater to our customers, we operate data centers in both the US and EU, specifically offering EU-based centers for those in the European Union.',
      'We are SOC 2 Type 2 Certified and GDPR compliant.',
    ];
const badgeImageSrc = data?.badgeImage?.asset?.url ?? 'https://www.desk365.io/wp-content/uploads/2024/09/secwebp.webp';
const badgeImageAlt = data?.badgeImageAlt ?? 'SOC 2 and GDPR compliance badges';

let sanityAttr: string | undefined;
let badgeImgAttr: string | undefined;
if (docId && data?._key) {
  try {
    const da = createDataAttribute({ id: docId, type: docType });
    sanityAttr = da(`pageBuilder[_key=="${data._key}"]`);
    badgeImgAttr = da(`pageBuilder[_key=="${data._key}"].badgeImage`);
  } catch {}
}
---

{styleProps?.css && <style is:inline set:html={styleProps.css} />}
<section
  id={styleProps?.sectionId ?? 'd365-security'}
  class:list={['d365-security', 'd365-section--blue-light', styleProps?.extraClass]}
  style={styleProps?.inlineStyle || undefined}
  data-sanity={sanityAttr}
>
  <div class="d365-container">
    <div class="d365-security__inner">

      <div class="d365-security__text">
        <h2 class="d365-heading">{heading}</h2>
        <ul class="d365-security__list">
          {bullets.map(bullet => (
            <li class="d365-security__bullet">
              <span class="d365-security__bullet-icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18" style="color: var(--d365-green)">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                </svg>
              </span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="d365-security__badges">
        <img
          src={badgeImageSrc}
          alt={badgeImageAlt}
          class="d365-security__badge-img"
          loading="lazy"
          data-sanity={badgeImgAttr}
        />
      </div>

    </div>
  </div>
</section>

<style>
  .d365-security {
    padding: 80px 24px;
  }

  .d365-security__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 800px) {
    .d365-security__inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  .d365-security__list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .d365-security__bullet {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 15px;
    color: var(--d365-text-body);
    line-height: 1.65;
  }

  .d365-security__bullet-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .d365-security__badges {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .d365-security__badge-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    object-fit: contain;
  }
</style>
