---
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';
import type { D365AIFeaturesSection, D365SectionStyleProps } from '../../lib/types';

interface Props {
  data?: D365AIFeaturesSection;
  isPreview?: boolean;
  docId?: string;
  docType?: string;
  styleProps?: D365SectionStyleProps;
}

const { data, docId, docType = 'homepage', styleProps } = Astro.props;

const heading = data?.heading ?? 'Less busywork. More human support.';
const body = data?.body ?? "Desk365's AI is different. It works in the background to reduce workload and stand-in to automate repetitive tasks so agents can do what they do best – be human.";

const staticCards = [
  { id: 'agent',  label: 'AI Agent',  description: 'Build, train, and deploy multiple AI Agents that chat with customers and handle simple, repetitive queries. Customize their personality, train them on your knowledge, and deploy them across channels like your website and support portal to deflect L1 tickets and reduce agent workload.', readMoreHref: '/ai-agent/', imageSrc: 'https://www.desk365.io/wp-content/uploads/2026/02/Desk365-AI-Agent-1.webp', imageAlt: 'Desk365 AI Agent interface', subFeatures: [] as {title:string;description:string}[] },
  { id: 'copilot', label: 'AI Copilot', description: 'AI Copilot empowers agents to work smarter and faster with intelligent assistance built right into the ticket view.', readMoreHref: '/ai-agent/', imageSrc: 'https://www.desk365.io/wp-content/uploads/2026/03/AI-Copilot-ss.png.webp', imageAlt: 'Desk365 AI Copilot interface', subFeatures: [{title:'Generate KB Article',description:'Create comprehensive knowledge base articles based on ticket details.'},{title:'Summarize Ticket',description:'Get clear, concise ticket summaries without having to read through lengthy tickets.'},{title:'Draft with AI',description:'Translate, edit, and perfect your responses with the AI editor.'}] },
];

const cards = data?.cards?.length
  ? data.cards.map((c, i) => ({ id: c._key ?? `ai-${i}`, _key: c._key, label: c.label, description: c.description ?? '', readMoreHref: c.readMoreHref, imageSrc: c.image?.asset?.url ?? '', imageAlt: c.imageAlt ?? c.label, subFeatures: c.subFeatures ?? [] }))
  : staticCards;

let sanityAttr: string | undefined;
let daFn: ((path: string) => string) | undefined;
if (docId && data?._key) {
  try {
    const da = createDataAttribute({ id: docId, type: docType });
    sanityAttr = da(`pageBuilder[_key=="${data._key}"]`);
    daFn = (path: string) => da(path);
  } catch {}
}

function cardImgAttr(cardKey: string | undefined) {
  if (!daFn || !data?._key || !cardKey) return undefined;
  return daFn(`pageBuilder[_key=="${data._key}"].cards[_key=="${cardKey}"].image`);
}
---

{styleProps?.css && <style is:inline set:html={styleProps.css} />}
<section
  id={styleProps?.sectionId ?? 'd365-ai-features'}
  class:list={['d365-ai-features', 'd365-section--white', styleProps?.extraClass]}
  style={styleProps?.inlineStyle || undefined}
  data-sanity={sanityAttr}
>
  <div class="d365-container">
    <div class="d365-section-header">
      <h2 class="d365-heading">{heading}</h2>
      <p class="d365-body">{body}</p>
    </div>

    <div class="d365-ai-features__layout">
      <!-- Toggle cards -->
      <div class="d365-ai-features__cards">
        {cards.map((card, i) => (
          <div
            class={`d365-ai-card${i === 0 ? ' d365-ai-card--active' : ''}`}
            data-card={card.id}
          >
            <!-- Card header (always visible) -->
            <button class="d365-ai-card__header" data-toggle={card.id} aria-expanded={i === 0 ? 'true' : 'false'}>
              <div class="d365-icon-box d365-icon-box--ai">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--d365-purple); width:22px; height:22px;">
                  <path d="M12 2a2 2 0 0 1 2 2v1a2 2 0 0 1-4 0V4a2 2 0 0 1 2-2zM12 17a2 2 0 0 1 2 2v1a2 2 0 0 1-4 0v-1a2 2 0 0 1 2-2zM4 12a2 2 0 0 1-2-2V9a2 2 0 0 1 4 0v1a2 2 0 0 1-2 2zM19 12a2 2 0 0 1-2-2V9a2 2 0 0 1 4 0v1a2 2 0 0 1-2 2zM5.636 7.05a2 2 0 0 1-.293-2.829l.707-.707a2 2 0 0 1 2.829 2.829l-.707.707a2 2 0 0 1-2.536.293zM15.121 16.95a2 2 0 0 1-.293-2.829l.707-.707a2 2 0 0 1 2.829 2.829l-.707.707a2 2 0 0 1-2.536.293zM5.636 16.95a2 2 0 0 1-2.536-.293l-.707-.707a2 2 0 0 1 2.829-2.829l.707.707a2 2 0 0 1-.293 2.829zM15.121 7.05a2 2 0 0 1-2.536-.293l-.707-.707A2 2 0 0 1 14.707 3.22l.707.707a2 2 0 0 1-.293 2.829z" />
                </svg>
              </div>
              <span class="d365-ai-card__label">{card.label}</span>
              <svg class="d365-ai-card__chevron" viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>

            <!-- Card body (collapsible) -->
            <div class="d365-ai-card__body">
              <p class="d365-ai-card__desc">{card.description}</p>

              {card.subFeatures && (
                <ul class="d365-ai-card__sub-list">
                  {card.subFeatures.map(sf => (
                    <li class="d365-ai-card__sub-item">
                      <span class="d365-ai-card__sub-icon">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16" style="color: var(--d365-purple)">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                      </span>
                      <div>
                        <strong class="d365-ai-card__sub-title">{sf.title}</strong>
                        <p class="d365-ai-card__sub-desc">{sf.description}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              )}

              {card.readMoreHref && (
                <a href={card.readMoreHref} class="d365-link">Read more</a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Image panel -->
      <div class="d365-ai-features__image-wrap">
        {cards.map((card, i) => (
          <img
            src={card.imageSrc}
            alt={card.imageAlt || card.label}
            class={`d365-ai-features__img${i === 0 ? ' d365-ai-features__img--active' : ''}`}
            data-img={card.id}
            loading={i === 0 ? 'eager' : 'lazy'}
            data-sanity={cardImgAttr((card as any)._key)}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .d365-ai-features {
    padding: 80px 24px;
  }

  .d365-ai-features__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 960px) {
    .d365-ai-features__layout {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  /* ── AI Toggle Cards ────────────────────────────────────────────── */
  .d365-ai-features__cards {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .d365-ai-card {
    border: 1px solid var(--d365-border);
    border-radius: var(--d365-radius-card);
    overflow: hidden;
    background: #fff;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .d365-ai-card--active {
    border-color: var(--d365-blue);
    box-shadow: var(--d365-shadow-card);
  }

  .d365-ai-card__header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 24px;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .d365-ai-card__label {
    flex: 1;
    font-size: 17px;
    font-weight: 700;
    color: var(--d365-blue);
  }

  .d365-ai-card__chevron {
    color: var(--d365-blue);
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .d365-ai-card--active .d365-ai-card__chevron {
    transform: rotate(180deg);
  }

  /* Card body */
  .d365-ai-card__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.25s ease;
    padding: 0 24px;
  }
  .d365-ai-card--active .d365-ai-card__body {
    max-height: 600px;
    padding: 0 24px 24px;
  }

  .d365-ai-card__desc {
    font-size: 15px;
    color: var(--d365-text-body);
    line-height: 1.7;
    margin: 0 0 20px;
  }

  /* Sub-feature list */
  .d365-ai-card__sub-list {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .d365-ai-card__sub-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .d365-ai-card__sub-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .d365-ai-card__sub-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--d365-text-dark);
    display: block;
    margin-bottom: 2px;
  }

  .d365-ai-card__sub-desc {
    font-size: 13px;
    color: var(--d365-text-body);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Image panel ────────────────────────────────────────────────── */
  .d365-ai-features__image-wrap {
    position: relative;
    min-height: 300px;
  }

  .d365-ai-features__img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(63,81,181,0.14);
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }
  .d365-ai-features__img--active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('d365-ai-features');
    if (!section) return;

    section.querySelectorAll<HTMLButtonElement>('.d365-ai-card__header').forEach(btn => {
      btn.addEventListener('click', () => {
        const cardId = btn.dataset.toggle as string;

        section.querySelectorAll('.d365-ai-card').forEach(c => c.classList.remove('d365-ai-card--active'));
        section.querySelectorAll('.d365-ai-features__img').forEach(img => img.classList.remove('d365-ai-features__img--active'));

        btn.closest('.d365-ai-card')?.classList.add('d365-ai-card--active');
        section.querySelector<HTMLImageElement>(`[data-img="${cardId}"]`)?.classList.add('d365-ai-features__img--active');
      });
    });
  });
</script>
