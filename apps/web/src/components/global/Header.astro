---
import type { NavigationHeader, SolutionsMenu } from '../../lib/types';
import { DEFAULT_NAV } from '../../lib/nav-data';

interface Props {
  nav?: NavigationHeader;
  solutionsMenu?: SolutionsMenu;
  currentLang?: string;
}

