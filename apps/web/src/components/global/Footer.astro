---
import type { NavigationFooter } from '../../lib/types';
import { DEFAULT_NAV } from '../../lib/nav-data';

interface Props {
  nav?: NavigationFooter;
  currentLang?: string;
}

const { nav = DEFAULT_NAV.footer, currentLang = 'en' } = Astro.props;
const { logo, logoAlt, copyrightText } = nav;
const columns     = nav.columns     ?? [];
const legalLinks  = nav.legalLinks  ?? [];
const socialLinks = nav.socialLinks ?? [];

// Find each column by heading
const featuresCol      = columns.find(c => c.heading.toLowerCase() === 'features');
const msTeamsCol       = columns.find(c => c.heading.toLowerCase().includes('microsoft'));
const forIndustriesCol = columns.find(c => c.heading.toLowerCase().includes('industr'));
const forTeamsCol      = columns.find(c => c.heading.toLowerCase() === 'for teams');
const companyCol       = columns.find(c => c.heading.toLowerCase() === 'company');
const alternativesCol  = columns.find(c => c.heading.toLowerCase().includes('altern'));
const resourcesCol     = columns.find(c => c.heading.toLowerCase() === 'resources');

// Split legal links: "Do Not Sell" goes center, rest go right
const doNotSellLink  = legalLinks.find(l => l.label.toLowerCase().includes('do not sell'));
const rightLegalLinks = legalLinks.filter(l => !l.label.toLowerCase().includes('do not sell'));

// G2 Spring 2026 badges
const g2Badges = [
  { title: 'Easiest To Do Business With', sub: '' },
  { title: 'Best Support',                sub: 'MID MARKET' },
  { title: 'High Performer',              sub: '' },
  { title: 'Users Love Us',               sub: '' },
];
---

<footer class="bg-[#282C81] text-white" aria-label="Site footer">

  <!-- ─── Main columns ──────────────────────────────────────────────── -->
  <div class="max-w-[1320px] mx-auto px-6 pt-14 pb-10">
    <div class="flex gap-10 xl:gap-14">

      <!-- Left panel: Logo + email + social -->
      <div class="flex-shrink-0 w-44">
        <a href="/" aria-label="Desk365 home">
          {logo?.asset?.url ? (
            <img
              src={logo.asset.url}
              alt={logoAlt ?? 'Desk365'}
              class="h-8 w-auto brightness-0 invert"
              width="140"
              height="32"
            />
          ) : (
            <img
              src="/desk365io-logo.png"
              alt={logoAlt ?? 'Desk365.io'}
              class="h-8 w-auto brightness-0 invert"
              width="140"
              height="32"
            />
          )}
        </a>

        <div class="mt-7 space-y-3.5">
          <!-- Email -->
          <a
            href="mailto:info@desk365.io"
            class="flex items-center gap-2.5 text-sm text-white/65 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            info@desk365.io
          </a>

          <!-- Social links -->
          {socialLinks.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2.5 text-sm text-white/65 hover:text-white transition-colors"
            >
              {s.platform === 'linkedin' && (
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
              {s.platform === 'youtube' && (
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {s.platform === 'twitter' && (
                <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              <span>
                {s.platform === 'twitter' ? 'X' : s.platform.charAt(0).toUpperCase() + s.platform.slice(1)}
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns (6) -->
      <div class="flex-1 grid grid-cols-6 gap-x-5 gap-y-10">

        <!-- 1. Features -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">Features</h3>
          <ul class="space-y-2" role="list">
            {(featuresCol?.links ?? []).map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 hover:text-white transition-colors leading-snug block"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- 2. Microsoft Teams -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">Microsoft Teams</h3>
          <ul class="space-y-3" role="list">
            {(msTeamsCol?.links ?? []).map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 hover:text-white transition-colors leading-snug block"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- 3. For Industries + For Teams (comma-separated inline) -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">For Industries</h3>
          <p class="text-sm text-white/70 leading-relaxed">
            {(forIndustriesCol?.links ?? []).map((link, i, arr) => (
              <>
                <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>{i < arr.length - 1 ? ', ' : ''}
              </>
            ))}
          </p>

          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mt-7 mb-4">For Teams</h3>
          <p class="text-sm text-white/70 leading-relaxed">
            {(forTeamsCol?.links ?? []).map((link, i, arr) => (
              <>
                <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>{i < arr.length - 1 ? ', ' : ''}
              </>
            ))}
          </p>
        </div>

        <!-- 4. Company -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">Company</h3>
          <ul class="space-y-2.5" role="list">
            {(companyCol?.links ?? []).map(link => (
              <li>
                <a href={link.href} class="text-sm text-white/70 hover:text-white transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- 5. Alternatives -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">Alternatives</h3>
          <ul class="space-y-2.5" role="list">
            {(alternativesCol?.links ?? []).map(link => (
              <li>
                <a href={link.href} class="text-sm text-white/70 hover:text-white transition-colors">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- 6. Resources -->
        <div>
          <h3 class="text-[11px] font-semibold text-white/50 uppercase tracking-[0.1em] mb-4">Resources</h3>
          <ul class="space-y-2.5" role="list">
            {(resourcesCol?.links ?? []).map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/70 hover:text-white transition-colors"
                  {...link.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>

  <!-- ─── Separator ─────────────────────────────────────────────────── -->
  <div class="border-t border-white/15"></div>

  <!-- ─── Badge strip ───────────────────────────────────────────────── -->
  <div class="max-w-[1320px] mx-auto px-6 py-7 flex flex-wrap items-center justify-between gap-6">

    <!-- Compliance badges: HIPAA · AICPA SOC · GDPR -->
    <div class="flex items-center gap-5">

      <!-- HIPAA -->
      <div
        class="w-[76px] h-[76px] rounded-full border border-white/25 bg-white/5 flex flex-col items-center justify-center gap-1"
        title="HIPAA Compliant"
      >
        <svg class="w-7 h-7" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M14 3C9 6 4 8 4 14c0 5.5 4.5 9.5 10 11 5.5-1.5 10-5.5 10-11 0-6-5-8-10-11z" stroke="white" stroke-opacity="0.6" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M14 9v10M9 14h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="text-[9px] font-bold text-white/80 tracking-wide">HIPAA</span>
      </div>

      <!-- AICPA SOC -->
      <div title="AICPA SOC 2 Certified">
        <svg class="w-[76px] h-[76px]" viewBox="0 0 76 76" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M38 4L70 17v22c0 18-14 28-32 33C20 67 6 57 6 39V17L38 4z" fill="white" fill-opacity="0.06" stroke="white" stroke-opacity="0.25" stroke-width="1.5"/>
          <text x="38" y="33" text-anchor="middle" fill="white" fill-opacity="0.6" font-family="system-ui,sans-serif" font-weight="700" font-size="8.5">AICPA</text>
          <text x="38" y="47" text-anchor="middle" fill="white" fill-opacity="0.9" font-family="system-ui,sans-serif" font-weight="800" font-size="14">SOC</text>
          <text x="38" y="59" text-anchor="middle" fill="white" fill-opacity="0.55" font-family="system-ui,sans-serif" font-weight="600" font-size="7.5">CERTIFIED</text>
        </svg>
      </div>

      <!-- GDPR -->
      <div
        class="w-[76px] h-[76px] rounded-full border border-white/25 bg-white/5 flex flex-col items-center justify-center gap-1"
        title="GDPR Compliant"
      >
        <svg class="w-10 h-10" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- EU circle of 12 stars (simplified as dots) -->
          <circle cx="20" cy="6"    r="1.4" fill="#FFD700"/>
          <circle cx="27"  cy="8"   r="1.4" fill="#FFD700"/>
          <circle cx="32"  cy="13"  r="1.4" fill="#FFD700"/>
          <circle cx="34"  cy="20"  r="1.4" fill="#FFD700"/>
          <circle cx="32"  cy="27"  r="1.4" fill="#FFD700"/>
          <circle cx="27"  cy="32"  r="1.4" fill="#FFD700"/>
          <circle cx="20"  cy="34"  r="1.4" fill="#FFD700"/>
          <circle cx="13"  cy="32"  r="1.4" fill="#FFD700"/>
          <circle cx="8"   cy="27"  r="1.4" fill="#FFD700"/>
          <circle cx="6"   cy="20"  r="1.4" fill="#FFD700"/>
          <circle cx="8"   cy="13"  r="1.4" fill="#FFD700"/>
          <circle cx="13"  cy="8"   r="1.4" fill="#FFD700"/>
          <text x="20" y="23" text-anchor="middle" fill="white" fill-opacity="0.9" font-family="system-ui,sans-serif" font-weight="700" font-size="8">GDPR</text>
        </svg>
      </div>

    </div>

    <!-- G2 Spring 2026 badges -->
    <div class="flex items-center gap-3">
      {g2Badges.map(badge => (
        <a
          href="https://www.g2.com/products/desk365/reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white rounded-xl w-[86px] h-[108px] flex flex-col items-center justify-between px-2 pt-2.5 pb-2 hover:scale-[1.03] transition-transform shadow-lg"
          aria-label={`G2 Award: ${badge.title}`}
        >
          <!-- Top row: SPRING 2026 + G2 circle -->
          <div class="w-full flex items-start justify-between">
            <div class="text-[7px] font-black text-orange-600 uppercase leading-tight tracking-wide">
              SPRING<br/>2026
            </div>
            <div class="w-[18px] h-[18px] bg-[#FF4800] rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-white font-black text-[7px] leading-none">G2</span>
            </div>
          </div>
          <!-- Award title -->
          <div class="text-center px-0.5">
            <div class="text-[9px] font-bold text-gray-800 leading-tight">{badge.title}</div>
            {badge.sub && (
              <div class="text-[7px] text-gray-400 mt-0.5 font-semibold tracking-wide">{badge.sub}</div>
            )}
          </div>
          <!-- Stars row -->
          <div class="flex items-center gap-px">
            {[0,1,2,3,4].map(() => (
              <svg class="w-[9px] h-[9px]" viewBox="0 0 10 10" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polygon points="5,0.5 6.18,3.82 9.76,3.82 6.94,5.97 7.94,9.45 5,7.5 2.06,9.45 3.06,5.97 0.24,3.82 3.82,3.82" fill="#FF6B2B"/>
              </svg>
            ))}
          </div>
        </a>
      ))}
    </div>

  </div>

  <!-- ─── Separator ─────────────────────────────────────────────────── -->
  <div class="border-t border-white/15"></div>

  <!-- ─── Legal bar ─────────────────────────────────────────────────── -->
  <div class="max-w-[1320px] mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs text-white/50">{copyrightText}</p>

    {doNotSellLink && (
      <a
        href={doNotSellLink.href}
        class="text-xs text-white/50 underline underline-offset-2 hover:text-white transition-colors"
      >
        {doNotSellLink.label}
      </a>
    )}

    <nav class="flex items-center gap-4" aria-label="Legal links">
      {rightLegalLinks.map(link => (
        <a
          href={link.href}
          class="text-xs text-white/50 hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>

</footer>
