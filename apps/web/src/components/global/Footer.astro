---
import type { NavigationFooter } from '../../lib/types';
import { DEFAULT_NAV } from '../../lib/nav-data';

interface Props {
  nav?: NavigationFooter;
  currentLang?: string;
}

const { nav = DEFAULT_NAV.footer, currentLang = 'en' } = Astro.props;
const { logo, logoAlt, tagline, copyrightText } = nav;
const columns     = nav.columns     ?? [];
const legalLinks  = nav.legalLinks  ?? [];
const socialLinks = nav.socialLinks ?? [];
const badgeImages = nav.badgeImages ?? [];
const languages   = nav.languages   ?? [];

const currentLanguage = languages?.find(l => l.code === currentLang) ?? languages?.[0];
---

<footer class="bg-[#0F172A] text-gray-400" aria-label="Site footer">

  <!-- ─── Main columns ──────────────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-3 lg:grid-cols-7">
      {columns.map((col) => (
        <div class="col-span-1">
          <h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">
            {col.heading}
          </h3>
          <ul class="space-y-2.5" role="list">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors leading-snug"
                  {...link.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- ─── Divider ───────────────────────────────────────────────── -->
  <div class="border-t border-white/10"></div>

  <!-- ─── Bottom bar ───────────────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">

      <!-- Left: Logo + tagline + copyright -->
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
        <!-- Logo -->
        <a href="/" aria-label="Desk365 home" class="flex-shrink-0">
          {logo?.asset?.url ? (
            <img
              src={logo.asset.url}
              alt={logoAlt ?? 'Desk365'}
              class="h-7 w-auto brightness-0 invert"
              width="96"
              height="28"
            />
          ) : (
            <svg width="96" height="28" viewBox="0 0 96 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="0" y="2" width="22" height="22" rx="5" fill="white" fill-opacity="0.9"/>
              <path d="M5 9.5h12M5 14h8.5M5 18.5h10" stroke="#0F172A" stroke-width="2" stroke-linecap="round"/>
              <text x="28" y="19" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="13" fill="white">desk365</text>
            </svg>
          )}
        </a>

        {tagline && (
          <p class="text-xs text-gray-500 max-w-xs lg:max-w-none">{tagline}</p>
        )}
      </div>

      <!-- Center: Social icons -->
      <div class="flex items-center gap-3">
        {socialLinks?.map(social => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
            aria-label={social.platform}
          >
            {social.platform === 'linkedin' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {social.platform === 'youtube' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            )}
            {social.platform === 'twitter' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {social.platform === 'facebook' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            )}
            {social.platform === 'instagram' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            )}
          </a>
        ))}

        {badgeImages?.map(badge => (
          <a
            href={badge.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-white/5 hover:bg-white/10 transition-colors"
            aria-label={badge.label ?? badge.alt}
          >
            {badge.image?.asset?.url ? (
              <img
                src={badge.image.asset.url}
                alt={badge.alt}
                class="h-5 w-auto"
                loading="lazy"
              />
            ) : (
              <span class="text-xs font-medium text-gray-300">{badge.alt}</span>
            )}
          </a>
        ))}
      </div>

      <!-- Right: Language switcher -->
      <div class="relative" id="footer-lang-switcher">
        <button
          type="button"
          id="footer-lang-btn"
          class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white bg-white/5 hover:bg-white/10 rounded-lg transition-colors border border-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-label="Select language"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
          </svg>
          <span id="footer-lang-label">{currentLanguage?.label ?? 'English'}</span>
          <svg class="w-3.5 h-3.5 transition-transform duration-150" id="footer-lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="footer-lang-panel"
          class="absolute bottom-full mb-2 right-0 w-72 bg-[#1E293B] border border-white/10 rounded-xl shadow-2xl p-3 hidden z-50"
          role="listbox"
          aria-label="Language options"
        >
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest px-2 mb-2.5">Select Language</p>
          <div class="grid grid-cols-2 gap-0.5">
            {languages?.map(lang => (
              <a
                href={lang.href}
                role="option"
                aria-selected={lang.code === currentLang}
                class={`px-3 py-2 text-sm rounded-lg transition-colors ${lang.code === currentLang ? 'bg-blue-600/20 text-blue-400 font-semibold' : 'text-gray-300 hover:bg-white/10 hover:text-white'}`}
              >
                {lang.label}
              </a>
            ))}
          </div>
        </div>
      </div>

    </div>

    <!-- ─── Legal row ──────────────────────────────────────────── -->
    <div class="mt-5 pt-5 border-t border-white/5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-gray-500">{copyrightText}</p>
      <nav class="flex flex-wrap gap-x-4 gap-y-1" aria-label="Legal links">
        {legalLinks?.map(link => (
          <a
            href={link.href}
            class="text-xs text-gray-500 hover:text-gray-300 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('footer-lang-btn');
  const panel = document.getElementById('footer-lang-panel');
  const chevron = document.getElementById('footer-lang-chevron');

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !panel?.classList.contains('hidden');
    panel?.classList.toggle('hidden', isOpen);
    chevron?.classList.toggle('rotate-180', !isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('footer-lang-switcher')?.contains(e.target as Node)) {
      panel?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel?.classList.contains('hidden')) {
      panel?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.focus();
    }
  });
</script>
