---
import type { CtaSection } from '../../lib/types';
import SectionCustomCode from './SectionCustomCode.astro';

interface Props { section: CtaSection }
const { section } = Astro.props;
const { _key, key, heading, subheading, primaryCta, secondaryCta, footnote, bgStyle = 'brand', customCode } = section;

const sectionId = `section-${_key ?? key ?? 'cta'}`;

const bg = { white: 'bg-white', light: 'bg-gray-50', dark: 'bg-gray-900', brand: 'bg-blue-600' }[bgStyle];
const headingClass = bgStyle === 'dark' || bgStyle === 'brand' ? 'text-white' : 'text-gray-900';
const subClass = bgStyle === 'dark' ? 'text-gray-300' : bgStyle === 'brand' ? 'text-blue-100' : 'text-gray-500';
const footnoteClass = bgStyle === 'dark' ? 'text-gray-400' : bgStyle === 'brand' ? 'text-blue-200' : 'text-gray-400';

const primaryClass = bgStyle === 'brand'
  ? 'inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-blue-600 bg-white rounded-xl hover:bg-blue-50 transition-colors shadow-sm'
  : 'inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm';

const secondaryClass = bgStyle === 'brand'
  ? 'inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-white border border-white/30 rounded-xl hover:bg-white/10 transition-colors'
  : 'inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-gray-700 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors';
---

<section id={sectionId} class={`py-20 px-4 ${bg}`}>
  <div class="max-w-3xl mx-auto text-center">
    {heading && <h2 class={`text-4xl font-bold tracking-tight ${headingClass}`}>{heading}</h2>}
    {subheading && <p class={`mt-4 text-lg leading-relaxed ${subClass}`}>{subheading}</p>}
    {(primaryCta?.label || secondaryCta?.label) && (
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        {primaryCta?.label && <a href={primaryCta.href} class={primaryClass}>{primaryCta.label}</a>}
        {secondaryCta?.label && <a href={secondaryCta.href} class={secondaryClass}>{secondaryCta.label}</a>}
      </div>
    )}
    {footnote && <p class={`mt-4 text-sm ${footnoteClass}`}>{footnote}</p>}
  </div>

  {customCode?.enabled && (
    <SectionCustomCode
      sectionId={sectionId}
      html={customCode.html}
      css={customCode.css}
      javascript={customCode.javascript}
    />
  )}
</section>
