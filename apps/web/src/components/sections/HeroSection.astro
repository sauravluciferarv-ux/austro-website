---
import type { HeroSection } from '../../lib/types';
interface Props { section: HeroSection }
const { section } = Astro.props;
const {
  badge,
  headline,
  headlineHighlight,
  highlightColor = 'blue',
  subheadline,
  primaryCta,
  secondaryCta,
  footnote,
  heroImage,
  heroImageAlt,
  layout = 'split',
} = section;

const parts = headlineHighlight ? headline.split(headlineHighlight) : null;

const highlightClass: Record<string, string> = {
  blue: 'text-blue-600',
  fuchsia: 'text-fuchsia-500',
  green: 'text-green-600',
  orange: 'text-orange-500',
};

const btnFilledClass: Record<string, string> = {
  blue: 'bg-blue-600 hover:bg-blue-700 text-white',
  green: 'bg-green-600 hover:bg-green-700 text-white',
  dark: 'bg-gray-900 hover:bg-gray-800 text-white',
  white: 'bg-white hover:bg-gray-50 text-gray-900',
};

const btnOutlineClass: Record<string, string> = {
  blue: 'border border-blue-600 text-blue-600 hover:bg-blue-50',
  green: 'border border-green-600 text-green-600 hover:bg-green-50',
  dark: 'border border-gray-800 text-gray-800 hover:bg-gray-50',
  white: 'border border-white text-white hover:bg-white/10',
};

function ctaClass(cta: typeof primaryCta) {
  const color = cta?.color ?? 'blue';
  const style = cta?.style ?? 'filled';
  const base = 'inline-flex items-center justify-center px-6 py-3.5 text-sm font-bold uppercase tracking-wide rounded-lg transition-colors shadow-sm';
  if (style === 'outline') return `${base} bg-transparent ${btnOutlineClass[color] ?? btnOutlineClass.blue}`;
  if (style === 'ghost') return `${base} bg-transparent text-current hover:underline shadow-none`;
  return `${base} ${btnFilledClass[color] ?? btnFilledClass.blue}`;
}

const isSplit = layout === 'split';
---

<section class="py-16 px-6 bg-white">
  <div class={`max-w-6xl mx-auto ${isSplit ? 'grid md:grid-cols-2 gap-12 items-center' : 'flex flex-col items-center text-center'}`}>

    <!-- Text content -->
    <div>
      {badge && (
        <span class="inline-flex items-center gap-1.5 bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-5">
          {badge}
        </span>
      )}

      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight leading-tight">
        {parts
          ? <>{parts[0]}<span class={highlightClass[highlightColor] ?? 'text-blue-600'}>{headlineHighlight}</span>{parts[1]}</>
          : headline
        }
      </h1>

      {subheadline && (
        <p class="mt-5 text-lg text-gray-500 leading-relaxed max-w-lg">
          {subheadline}
        </p>
      )}

      {(primaryCta?.label || secondaryCta?.label) && (
        <div class={`mt-8 flex flex-wrap gap-3 ${isSplit ? '' : 'justify-center'}`}>
          {primaryCta?.label && (
            <a href={primaryCta.href} class={ctaClass(primaryCta)}>
              {primaryCta.label}
            </a>
          )}
          {secondaryCta?.label && (
            <a href={secondaryCta.href} class={ctaClass(secondaryCta)}>
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}

      {footnote && (
        <p class="mt-3 text-sm text-gray-400">{footnote}</p>
      )}
    </div>

    <!-- Image -->
    {heroImage && (
      <div class={isSplit ? '' : 'mt-14 w-full max-w-5xl'}>
        <img
          src={heroImage.asset.url}
          alt={heroImageAlt || heroImage.alt || ''}
          class="w-full rounded-2xl shadow-2xl ring-1 ring-gray-200"
          loading="eager"
        />
      </div>
    )}

  </div>
</section>
