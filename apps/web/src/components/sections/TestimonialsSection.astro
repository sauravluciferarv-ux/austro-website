---
/**
 * TestimonialsSection
 * Sanity fields: heading, subheading, testimonials[]
 * Each testimonial: quote, body, authorName, authorTitle, industry, companyLogo
 */
import type { TestimonialsSection } from '../../lib/types';
import SectionCustomCode from './SectionCustomCode.astro';

interface Props { section?: TestimonialsSection }
const { section } = Astro.props;

const sectionId = `section-${section?._key ?? section?.key ?? 'testimonials'}`;

const heading    = section?.heading    ?? "Don't just take our word for it, see why our customers choose us!";
const subheading = section?.subheading ?? 'Hear from real people who have experienced the difference.';
const customCode = section?.customCode;

const STATIC_ITEMS = [
  {
    quote:      'They really make you feel they are part of your team.',
    body:       'Desk365 does what you expect from a much more expensive ticket system. The best thing however is the customer support. All questions about the software are answered quickly and completely and suggestions for improvement are treated seriously. They really make you feel they are part of your team.',
    authorName: 'Jeroen H',
    authorTitle:'Scientist Sensortechnologies',
    industry:   'Biotechnology',
    companyLogo: null,
  },
  {
    quote:      'A very good system all round.',
    body:       'After testing many other helpdesk solutions, we have been utilizing Desk365 for 10 months and have been hugely impressed with its ease of use, speed and simplicity. Everything we need to provide excellent customer support via email is available in one place, updates on new features are regular and concise.',
    authorName: 'Andy Roberts',
    authorTitle:'Network & Communications Support Specialist, CSG',
    industry:   null,
    companyLogo: null,
  },
  {
    quote:      'Transformed how our IT team handles support.',
    body:       'We moved from a spreadsheet-based system to Desk365 and the difference is night and day. The automation rules alone saved us hours every week. The Microsoft Teams integration is seamless and our agents love working with it every day.',
    authorName: 'Sarah Mitchell',
    authorTitle:'IT Manager, Mercer Group',
    industry:   'Financial Services',
    companyLogo: null,
  },
  {
    quote:      'The best helpdesk for a growing team.',
    body:       'We evaluated five platforms before choosing Desk365. The value for money is unmatched. Setup was straightforward and the support team guided us every step of the way. Our average response time improved by 40% within the first month.',
    authorName: 'David Park',
    authorTitle:'Head of Operations, TechStart Inc',
    industry:   'SaaS',
    companyLogo: null,
  },
  {
    quote:      'Incredible value and outstanding customer support.',
    body:       'Desk365 has everything we need at a price that makes sense for a nonprofit. The knowledge base feature alone has cut repetitive tickets in half. Highly recommended for mission-driven organizations that need to watch their budget carefully.',
    authorName: 'Monica Leal',
    authorTitle:'Director of IT, Bright Futures Foundation',
    industry:   'Non-Profit',
    companyLogo: null,
  },
  {
    quote:      'Finally a helpdesk our whole team actually uses.',
    body:       'Previous tools felt clunky and our agents would avoid them. With Desk365 adoption was immediate. The interface is clean, ticket routing is smart, and the reporting gives us exactly the insights we need to keep improving.',
    authorName: 'Raj Patel',
    authorTitle:'Customer Success Lead, Cloudbridge Solutions',
    industry:   'MSP',
    companyLogo: null,
  },
];

const items = (section?.testimonials && section.testimonials.length > 0)
  ? section.testimonials
  : STATIC_ITEMS;
---

<section id={sectionId} class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <div class="text-center mb-14">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-[#1a2d6b] leading-tight max-w-3xl mx-auto">
        {heading}
      </h2>
      <p class="mt-3 text-base text-gray-500 italic">{subheading}</p>
    </div>

    <!-- ── Carousel ───────────────────────────────────────────── -->
    <div class="overflow-hidden" id="testi-viewport">
      <div
        id="testi-track"
        class="flex"
        style="gap:24px; transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94);"
      >
        {items.map((item) => (
          <div class="testi-slide flex-shrink-0" style="width: calc(50% - 12px);">
            <!-- quote-badge floats above the card -->
            <div class="relative pt-5">
              <div class="absolute top-0 left-5 z-10 flex items-center justify-center w-10 h-10 rounded-lg bg-[#dce6f8] shadow-sm">
                <svg class="w-5 h-5 text-[#1a2d6b]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M11 7H6a1 1 0 00-1 1v5a1 1 0 001 1h3v3a1 1 0 001 1h1a1 1 0 001-1V8a1 1 0 00-1-1zm8 0h-5a1 1 0 00-1 1v5a1 1 0 001 1h3v3a1 1 0 001 1h1a1 1 0 001-1V8a1 1 0 00-1-1z"/>
                </svg>
              </div>

              <!-- Card body -->
              <div class="bg-[#1a2d6b] rounded-2xl px-7 pt-10 pb-7 flex flex-col" style="min-height:320px;">

                <!-- Quote headline -->
                <p class="text-lg font-bold text-white leading-snug mb-4">
                  &ldquo;{item.quote}&rdquo;
                </p>

                <!-- Body text -->
                <p class="text-sm text-blue-100 leading-relaxed flex-1">
                  {item.body}
                </p>

                <!-- Author row -->
                <div class="mt-6 flex items-end justify-between gap-4">
                  <div>
                    <p class="text-sm font-bold text-white leading-tight">{item.authorName}</p>
                    {item.authorTitle && (
                      <p class="text-xs text-blue-300 mt-0.5 leading-snug">{item.authorTitle}</p>
                    )}
                  </div>

                  <!-- Industry label OR company logo -->
                  <div class="flex-shrink-0 text-right">
                    {(item as any).companyLogo?.asset?.url ? (
                      <img
                        src={(item as any).companyLogo.asset.url}
                        alt={item.authorName}
                        class="h-8 w-auto object-contain brightness-0 invert opacity-80"
                        loading="lazy"
                      />
                    ) : item.industry ? (
                      <p class="text-xs leading-tight">
                        <span class="block text-blue-300">Industry</span>
                        <span class="block text-blue-100 font-semibold">{item.industry}</span>
                      </p>
                    ) : null}
                  </div>
                </div>

              </div><!-- /card -->
            </div>
          </div>
        ))}
      </div>
    </div><!-- /viewport -->

    <!-- ── Controls ───────────────────────────────────────────── -->
    <div class="mt-8 flex items-center gap-3">

      <button
        id="testi-prev"
        type="button"
        aria-label="Previous"
        disabled
        class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-gray-300 text-gray-400 hover:border-[#1a2d6b] hover:text-[#1a2d6b] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1a2d6b] disabled:opacity-30 disabled:pointer-events-none"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <button
        id="testi-next"
        type="button"
        aria-label="Next"
        class="w-9 h-9 inline-flex items-center justify-center rounded-lg border border-gray-300 text-gray-400 hover:border-[#1a2d6b] hover:text-[#1a2d6b] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1a2d6b] disabled:opacity-30 disabled:pointer-events-none"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <!-- Progress track -->
      <div class="flex-1 h-0.5 bg-gray-200 rounded-full" role="progressbar" aria-label="Testimonials progress">
        <div id="testi-bar" class="h-full bg-[#1a2d6b] rounded-full" style="width:50%; transition: width 0.45s ease;"></div>
      </div>

    </div>

  </div>

  {customCode?.enabled && (
    <SectionCustomCode
      sectionId={sectionId}
      html={customCode.html}
      css={customCode.css}
      javascript={customCode.javascript}
    />
  )}
</section>

<script>
(() => {
  const viewport = document.getElementById('testi-viewport');
  const track    = document.getElementById('testi-track')    as HTMLElement | null;
  const prevBtn  = document.getElementById('testi-prev')     as HTMLButtonElement | null;
  const nextBtn  = document.getElementById('testi-next')     as HTMLButtonElement | null;
  const bar      = document.getElementById('testi-bar')      as HTMLElement | null;

  if (!viewport || !track || !prevBtn || !nextBtn || !bar) return;

  const slides     = Array.from(track.querySelectorAll<HTMLElement>('.testi-slide'));
  const CARD_GAP   = 24; // px — matches the gap style above
  let page         = 0;

  /* How many slides are visible at current breakpoint */
  const perPage = () => window.innerWidth >= 1024 ? 2 : 1;

  /* Total pages */
  const totalPages = () => Math.ceil(slides.length / perPage());

  /* Set each slide's CSS width so they fill the viewport correctly */
  function setWidths() {
    const pp = perPage();
    slides.forEach(s => {
      s.style.width = pp === 2
        ? `calc(50% - ${CARD_GAP / 2}px)`
        : '100%';
    });
  }

  /* Apply transform offset + update UI chrome */
  function go(newPage: number) {
    page = Math.max(0, Math.min(newPage, totalPages() - 1));

    const cardW  = slides[0]?.offsetWidth ?? 0;
    const offset = page * perPage() * (cardW + CARD_GAP);
    track.style.transform = `translateX(-${offset}px)`;

    const pct = ((page + 1) / totalPages()) * 100;
    bar.style.width = `${pct}%`;

    prevBtn.disabled = page === 0;
    nextBtn.disabled = page >= totalPages() - 1;
  }

  prevBtn.addEventListener('click', () => go(page - 1));
  nextBtn.addEventListener('click', () => go(page + 1));

  /* Touch/swipe support */
  let touchStartX = 0;
  viewport.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  viewport.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) diff > 0 ? go(page + 1) : go(page - 1);
  });

  /* Keyboard */
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  go(page - 1);
    if (e.key === 'ArrowRight') go(page + 1);
  });

  /* Responsive */
  let rTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(rTimer);
    rTimer = setTimeout(() => { page = 0; setWidths(); go(0); }, 150);
  });

  setWidths();
  go(0);
})();
</script>
