---
import type { PageSection } from '../lib/types';
import BlockRenderer from './blocks/BlockRenderer.astro';
import { createDataAttribute } from '@sanity/visual-editing/create-data-attribute';
import {
  resolveSpacing,
  resolveBackground,
  resolveBorder,
  resolveSize,
  resolveGap,
  resolveColumns,
  resolveSectionMaxWidth,
  resolveResponsiveCss,
  resolveScopedCss,
  mergeStyles,
} from '../lib/styleResolver';

interface Props {
  section: PageSection;
  isPreview?: boolean;
  docId?: string;
  docType?: string;
}

const { section, isPreview, docId, docType = 'page' } = Astro.props;

const key         = section._key ?? Math.random().toString(36).slice(2);
const sectionId   = section.sectionId || `section-${key}`;
const sectionClass = section.sectionClass || `pb-section-${key}`;

// ── Presentation tool click-to-edit ────────────────────────────────────────
let sectionSanityAttr: string | undefined;
if (docId && section._key) {
  try {
    const da = createDataAttribute({ id: docId, type: docType });
    sectionSanityAttr = da(`pageBuilder[_key=="${section._key}"]`);
  } catch { /* non-critical */ }
}

// ── Layout ──────────────────────────────────────────────────────────────────
const sec = section as any;

// Container (outer wrapper) max-width
const maxWidth = resolveSectionMaxWidth(sec.sectionWidth, sec.customSectionWidth);
const containerStyle = maxWidth ? `max-width:${maxWidth};margin-left:auto;margin-right:auto;width:100%;` : 'width:100%;';

// Column grid
const gridTemplate = resolveColumns(sec.columns, sec.customGridTemplate);
const columnGapPx  = resolveGap(sec.columnGap ?? sec.gap);
const rowGapPx     = resolveGap(sec.rowGap ?? sec.gap);

let blocksWrapStyle = '';
if (gridTemplate && gridTemplate !== '1fr') {
  blocksWrapStyle = `display:grid;grid-template-columns:${gridTemplate};`;
  if (columnGapPx) blocksWrapStyle += `column-gap:${columnGapPx};`;
  if (rowGapPx)    blocksWrapStyle += `row-gap:${rowGapPx};`;
} else {
  blocksWrapStyle = 'display:flex;flex-direction:column;';
  if (columnGapPx) blocksWrapStyle += `gap:${columnGapPx};`;
}

// Alignment on blocks wrapper
const vAlignMap: Record<string, string> = { start: 'flex-start', center: 'center', end: 'flex-end', stretch: 'stretch' };
const hAlignMap: Record<string, string> = { start: 'flex-start', center: 'center', end: 'flex-end', between: 'space-between', around: 'space-around' };
if (sec.verticalAlign)   blocksWrapStyle += `align-items:${vAlignMap[sec.verticalAlign] ?? 'flex-start'};`;
if (sec.horizontalAlign) blocksWrapStyle += `justify-content:${hAlignMap[sec.horizontalAlign] ?? 'flex-start'};`;

// ── Section inline styles ───────────────────────────────────────────────────
// Support new structured style objects AND legacy flat fields
const sectionStyle = mergeStyles(
  // New style objects (take priority)
  resolveBackground(sec.background),
  resolveBorder(sec.border),
  resolveSpacing(sec.spacing),
  resolveSize(sec.size),
  // Legacy flat spacing fields (fallback when new objects not set)
  !sec.spacing && sec.paddingTop    ? `padding-top:${sec.paddingTop}`       : '',
  !sec.spacing && sec.paddingBottom ? `padding-bottom:${sec.paddingBottom}` : '',
  !sec.spacing && sec.paddingLeft   ? `padding-left:${sec.paddingLeft}`     : '',
  !sec.spacing && sec.paddingRight  ? `padding-right:${sec.paddingRight}`   : '',
  !sec.spacing && sec.marginTop     ? `margin-top:${sec.marginTop}`         : '',
  !sec.spacing && sec.marginBottom  ? `margin-bottom:${sec.marginBottom}`   : '',
  // Legacy background fields (fallback)
  !sec.background && sec.bgColor    ? `background-color:${sec.bgColor}`    : '',
  !sec.background && sec.bgGradient ? `background:${sec.bgGradient}`       : '',
  !sec.background && sec.bgImage?.asset?.url
    ? `background-image:url('${sec.bgImage.asset.url}');background-size:cover;background-position:center`
    : '',
  // Legacy minHeight
  !sec.size && sec.minHeight        ? `min-height:${sec.minHeight}`         : '',
);

// ── Responsive CSS (media queries + visibility) ─────────────────────────────
const responsiveCss = resolveResponsiveCss(sectionClass, sec.responsive);

// Responsive column overrides
const responsiveColumnCss = [
  sec.tabletColumns
    ? `@media (min-width:768px) and (max-width:1023px){.${sectionClass} .pb-blocks-wrap{grid-template-columns:repeat(${sec.tabletColumns},1fr)}}`
    : '',
  sec.mobileColumns
    ? `@media (max-width:767px){.${sectionClass} .pb-blocks-wrap{grid-template-columns:repeat(${sec.mobileColumns},1fr)}}`
    : '',
].join('');

// Background image overlay (requires a pseudo-element, handled via scoped style)
const overlayColor = sec.background?.type === 'image' && sec.background?.overlay;
const overlayCss   = overlayColor
  ? `.${sectionClass}{position:relative}.${sectionClass}::after{content:'';position:absolute;inset:0;background:${overlayColor};pointer-events:none;}`
  : '';

// Section-level and block-level custom CSS
function collectCustomCss(): string {
  const parts: string[] = [];
  if (sec.customCss) {
    const hasBraces = /\{/.test(sec.customCss);
    parts.push(hasBraces ? sec.customCss : `.${sectionClass} { ${sec.customCss} }`);
  }
  for (const block of sec.blocks ?? []) {
    if (!block.customCss) continue;
    const blockCls = block.blockClass || `block-${block._key}`;
    const hasBraces = /\{/.test(block.customCss);
    parts.push(hasBraces ? block.customCss : `.${blockCls} { ${block.customCss} }`);
  }
  return parts.join('\n');
}

const allCustomCss = collectCustomCss();
const allInjectedCss = responsiveCss + responsiveColumnCss + overlayCss + allCustomCss;

// ── Legacy visibility ───────────────────────────────────────────────────────
// Prefer responsive object; fall back to old flat booleans
const hideOnMobile  = sec.responsive?.hideOnMobile  ?? sec.hideOnMobile  ?? false;
const hideOnDesktop = sec.responsive?.hideOnDesktop ?? sec.hideOnDesktop ?? false;
---

{allInjectedCss && <style is:inline set:html={allInjectedCss} />}

<section
  id={sectionId}
  class:list={[
    sectionClass,
    hideOnMobile  && 'hidden md:block',
    hideOnDesktop && 'block md:hidden',
    isPreview     && 'pb-section-wrapper',
  ]}
  style={sectionStyle || undefined}
  aria-label={sec.ariaLabel || undefined}
  data-section-id={sectionId}
  data-sanity={sectionSanityAttr}
>
  {isPreview && section.label && (
    <div class="pb-section-label">{section.label}</div>
  )}

  <div style={containerStyle}>
    <div class="pb-blocks-wrap" style={blocksWrapStyle}>
      {(section.blocks ?? []).map(block => (
        <BlockRenderer
          block={block}
          isPreview={isPreview}
          docId={docId}
          docType={docType}
          sectionKey={section._key}
        />
      ))}
    </div>
  </div>
</section>
