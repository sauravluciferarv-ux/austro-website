---
// SSR enables preview mode: the middleware reads the preview cookie and switches
// to draft content. In production, Vercel will cache this response automatically.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSectionRenderer from '../components/home/HomeSectionRenderer.astro';
import { sanityClient, getDraftClient } from '../lib/sanity';
import { homepagePageBuilderQuery } from '../lib/queries';
import type { HomepagePageBuilder } from '../lib/types';

// Static home sections — used as fallback when Sanity pageBuilder is empty
import HomeHeroSection          from '../components/home/HomeHeroSection.astro';
import HomeTrustBarSection      from '../components/home/HomeTrustBarSection.astro';
import HomeStatsSection         from '../components/home/HomeStatsSection.astro';
import HomeFeatureCardsSection  from '../components/home/HomeFeatureCardsSection.astro';
import HomeChannelsSection      from '../components/home/HomeChannelsSection.astro';
import HomeAIFeaturesSection    from '../components/home/HomeAIFeaturesSection.astro';
import HomeMicrosoftSection     from '../components/home/HomeMicrosoftSection.astro';
import HomeITSMSection          from '../components/home/HomeITSMSection.astro';
import HomeCapabilitiesSection  from '../components/home/HomeCapabilitiesSection.astro';
import HomeComparisonSection    from '../components/home/HomeComparisonSection.astro';
import HomeIntegrationsSection  from '../components/home/HomeIntegrationsSection.astro';
import HomeTestimonialsSection  from '../components/home/HomeTestimonialsSection.astro';
import HomeWhyChooseSection     from '../components/home/HomeWhyChooseSection.astro';
import HomeSecuritySection      from '../components/home/HomeSecuritySection.astro';
import HomeBlogSection          from '../components/home/HomeBlogSection.astro';
import HomeFinalCtaSection      from '../components/home/HomeFinalCtaSection.astro';

const isPreview = Astro.locals.isPreview;

const client = isPreview ? getDraftClient() : sanityClient;
const homepage = await client.fetch<HomepagePageBuilder>(homepagePageBuilderQuery);
const seo = homepage?.seo ?? {};
const docId = homepage?._id;

if (!isPreview) {
  Astro.response.headers.set(
    'Cache-Control',
    's-maxage=60, stale-while-revalidate=300'
  );
}

const pageBuilder = homepage?.pageBuilder ?? [];
---

<BaseLayout
  seo={{
    metaTitle: seo.metaTitle || 'AI-powered helpdesk software for teams of all sizes | Desk365',
    metaDescription: seo.metaDescription || 'A seamless AI-powered helpdesk solution built for businesses of all sizes. Simplify customer support with integrated ticketing, automation and a knowledge base.',
    ogImage: seo.ogImage,
  }}
>
  {/* Sanity page-builder content (d365* sections + generic pageSections) */}
  {pageBuilder.length > 0 && pageBuilder.map((section) => (
    <HomeSectionRenderer
      section={section as any}
      isPreview={isPreview}
      docId={docId}
      docType="homepage"
    />
  ))}

  {/* Static fallback — shown when Sanity pageBuilder is empty */}
  {pageBuilder.length === 0 && (
    <>
      <HomeHeroSection />
      <HomeTrustBarSection />
      <HomeStatsSection />
      <HomeFeatureCardsSection />
      <HomeChannelsSection />
      <HomeAIFeaturesSection />
      <HomeMicrosoftSection />
      <HomeITSMSection />
      <HomeCapabilitiesSection />
      <HomeComparisonSection />
      <HomeIntegrationsSection />
      <HomeTestimonialsSection />
      <HomeWhyChooseSection />
      <HomeSecuritySection />
      <HomeBlogSection />
      <HomeFinalCtaSection />
    </>
  )}
</BaseLayout>
