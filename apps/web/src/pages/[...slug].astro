---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSectionRenderer from '../components/home/HomeSectionRenderer.astro';
import { sanityClient, getDraftClient } from '../lib/sanity';
import { pageBySlugQuery } from '../lib/queries';
import type { PageBuilderPage } from '../lib/types';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/');

const isPreview = Astro.locals.isPreview ?? false;
const client = isPreview ? getDraftClient() : sanityClient;

const page = await client
  .fetch<PageBuilderPage>(pageBySlugQuery, { slug })
  .catch(() => null);

if (!page) {
  return new Response(null, { status: 404, statusText: 'Page not found' });
}

if (!isPreview) {
  Astro.response.headers.set(
    'Cache-Control',
    'public, max-age=60, stale-while-revalidate=300'
  );
}
---

<BaseLayout seo={page.seo}>
  {(page.pageBuilder ?? []).map(section => (
    <HomeSectionRenderer
      section={section as any}
      isPreview={isPreview}
      docId={page._id}
      docType="page"
    />
  ))}
</BaseLayout>
